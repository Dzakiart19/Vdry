{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/rb",    "destination": "/rb.html" },
      { "source": "/rb/**", "destination": "/rb.html" },
      { "source": "/yb",    "destination": "/yb.html" },
      { "source": "/yb/**", "destination": "/yb.html" },
      { "source": "/bk",    "destination": "/bk.html" },
      { "source": "/bk/**", "destination": "/bk.html" },
      { "source": "/tp",    "destination": "/tp.html" },
      { "source": "/tp/**", "destination": "/tp.html" },
      { "source": "/rc",    "destination": "/rc.html" },
      { "source": "/rc/**", "destination": "/rc.html" },
      { "source": "/sb",    "destination": "/sb.html" },
      { "source": "/sb/**", "destination": "/sb.html" },
      { "source": "/xn",    "destination": "/xn.html" },
      { "source": "/xn/**", "destination": "/xn.html" },
      { "source": "**",     "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/sitemap.xml",
        "headers": [
          { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      },
      {
        "source": "/robots.txt",
        "headers": [
          { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|svg|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      }
    ]
  }
}
